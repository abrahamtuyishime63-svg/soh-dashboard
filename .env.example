# ═══════════════════════════════════════════════════════════════
# Real Battery Cloud API Configuration
# Copy this file to .env and fill in your actual credentials
# ═══════════════════════════════════════════════════════════════

# API Server Port
API_PORT=3001
FRONTEND_PORT=5173

# ─── REAL CLOUD BMS INTEGRATION ────────────────────────────────
# Choose your battery cloud provider and add credentials

# Option 1: Tesla Battery Management System (BMS) Cloud
TESLA_BMS_ENABLED=false
TESLA_API_KEY=your_tesla_api_key_here
TESLA_API_URL=https://api.tesla.com/v1/battery
TESLA_POLLING_INTERVAL=60000

# Option 2: CATL Cloud Battery Platform
CATL_BMS_ENABLED=false
CATL_API_KEY=your_catl_api_key_here
CATL_API_URL=https://api.catl.com/battery
CATL_POLLING_INTERVAL=60000

# Option 3: LG Chem Battery Cloud
LG_BMS_ENABLED=false
LG_API_KEY=your_lg_api_key_here
LG_API_URL=https://api.lgchem.com/battery
LG_POLLING_INTERVAL=60000

# Option 4: BYD Battery Cloud
BYD_BMS_ENABLED=false
BYD_API_KEY=your_byd_api_key_here
BYD_API_URL=https://api.byd.com/battery
BYD_POLLING_INTERVAL=60000

# Option 5: Generic MQTT Cloud (IoT Broker)
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://broker.example.com:1883
MQTT_USERNAME=your_mqtt_user
MQTT_PASSWORD=your_mqtt_password
MQTT_TOPIC_PREFIX=battery/data

# Option 6: Generic REST API (Custom Cloud)
CUSTOM_REST_ENABLED=false
CUSTOM_REST_URL=https://your-battery-api.com/api/v1
CUSTOM_REST_API_KEY=your_api_key_here
CUSTOM_REST_POLLING_INTERVAL=60000

# ─── DATABASE CONFIGURATION ────────────────────────────────────
# For persistent storage of battery data and history
DATABASE_TYPE=sqlite
DATABASE_URL=./data/battery_history.db
# OR for PostgreSQL:
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/battery_soh

# ─── STANDARDS COMPLIANCE ─────────────────────────────────────
# Enable/disable standards monitoring and alerts
ISO_12405_ENABLED=true
IEC_61960_ENABLED=true
IEC_61850_ENABLED=true
ISO_80000_ENABLED=true

# Thermal reference temperature (°C)
THERMAL_REFERENCE_TEMP=25

# SoH Thresholds (ISO 12405-4)
SOH_THRESHOLD_HEALTHY=80
SOH_THRESHOLD_CAUTION=65
SOH_THRESHOLD_DEGRADED=40
SOH_THRESHOLD_EOL=0

# ─── REAL-TIME DATA STREAMING ────────────────────────────────
# WebSocket or SSE for live updates
STREAMING_TYPE=sse
STREAMING_INTERVAL=1000
HISTORICAL_DATA_RETENTION_DAYS=365

# ─── LOGGING & MONITORING ────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
MONITORING_ENABLED=true
METRICS_EXPORT_INTERVAL=300000

# ─── SECURITY ───────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_change_me
ADMIN_PASSWORD=admin123
API_RATE_LIMIT=100
RATE_LIMIT_WINDOW=900000
